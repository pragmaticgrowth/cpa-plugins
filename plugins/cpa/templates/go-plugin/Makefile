# CLIProxyAPI plugin Makefile (generated by /cpa:scaffold)
PLUGIN_ID ?= __PLUGIN_ID__

GOOS   := $(shell go env GOOS)
GOARCH := $(shell go env GOARCH)

ifeq ($(GOOS),windows)
EXT := dll
else ifeq ($(GOOS),darwin)
EXT := dylib
else
EXT := so
endif

ARTIFACT := $(PLUGIN_ID).$(EXT)
# Install target: <plugins.dir>/<GOOS>/<GOARCH>/<id>.<ext>. Override PLUGINS_DIR to your host's plugins dir.
PLUGINS_DIR ?= ./plugins
INSTALL_DIR := $(PLUGINS_DIR)/$(GOOS)/$(GOARCH)

.PHONY: build install clean tidy validate

build: tidy
	CGO_ENABLED=1 go build -buildmode=c-shared -o $(ARTIFACT) .
	@rm -f $(PLUGIN_ID).h
	@echo "built $(ARTIFACT) ($(GOOS)/$(GOARCH))"

tidy:
	go mod tidy

install: build
	mkdir -p $(INSTALL_DIR)
	cp $(ARTIFACT) $(INSTALL_DIR)/$(ARTIFACT)
	@echo "installed -> $(INSTALL_DIR)/$(ARTIFACT)"

# Confirm the ABI entrypoint is exported (macOS/Linux).
validate: build
	@nm -gU $(ARTIFACT) 2>/dev/null | grep -q cliproxy_plugin_init && echo "OK: cliproxy_plugin_init exported" || (echo "MISSING cliproxy_plugin_init" && exit 1)

clean:
	rm -f $(ARTIFACT) $(PLUGIN_ID).h
